{
  "name": "@saltify/milky-tea",
  "type": "module",
  "version": "0.1.3",
  "packageManager": "pnpm@10.30.3",
  "description": "Client library for Milky Protocol.",
  "author": "SaltifyDev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SaltifyDev/milky-tea.git"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "generate-api": "jiti ./scripts/generate-api.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "fmt": "eslint . --fix",
    "prepare": "pnpm run generate-api"
  },
  "peerDependencies": {
    "eventsource": "^4.1.0"
  },
  "peerDependenciesMeta": {
    "eventsource": {
      "optional": true
    }
  },
  "dependencies": {
    "@saltify/milky-types": "1.2.0-rc.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "@vitest/coverage-v8": "^4.1.3",
    "bumpp": "^10.4.1",
    "change-case": "^5.4.4",
    "eslint": "^10.2.0",
    "eventsource": "^4.1.0",
    "jiti": "^2.6.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
