{
  "name": "@saltify/milky",
  "type": "module",
  "version": "0.0.1",
  "description": "Client library for Milky Protocol.",
  "author": "SaltifyDev",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.mjs",
    "./events": "./dist/events/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "generate-api": "jiti ./scripts/generate-api.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "fmt": "eslint . --fix",
    "prepare": "pnpm run generate-api"
  },
  "dependencies": {
    "@saltify/milky-types": "1.2.0-rc.4",
    "mitt": "^3.0.1",
    "zod": "^4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "bumpp": "^10.4.1",
    "change-case": "^5.4.4",
    "eslint": "^10.0.3",
    "jiti": "^2.6.1",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
